# telegram-bridge/.env.example
# Copy to .env and fill. .env is gitignored.

# Bot token from @BotFather (https://t.me/BotFather).
# Treat like a password -- anyone with this can act as your bot.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to message the bot.
# Any message from an ID not on this list is silently dropped.
# Find your user ID by messaging @userinfobot.
# Example: TELEGRAM_ALLOWED_USER_IDS=12345678,87654321
TELEGRAM_ALLOWED_USER_IDS=
